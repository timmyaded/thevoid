<%- include('../partials/header', { pageTitle: 'Create Account' }) %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">The Void</div>
    <h1 class="auth-title">Create your account</h1>
    <p class="auth-sub">A space to write. A space to be heard.</p>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <form action="/register" method="POST" class="auth-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="yourname" required minlength="3" maxlength="30" />
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" placeholder="you@example.com" required />
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="At least 6 characters" required minlength="6" />
      </div>
      <div class="form-group">
        <label>Bio <span class="optional">(optional)</span></label>
        <input type="text" name="bio" placeholder="A short description about you" maxlength="200" />
      </div>
      <button type="submit" class="btn-primary full-width">Create account</button>
    </form>

    <p class="auth-switch">Already have an account? <a href="/login">Sign in</a></p>
  </div>
</div>

<%- include('../partials/footer') %>
