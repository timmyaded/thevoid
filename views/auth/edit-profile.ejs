<%- include('../partials/header', { pageTitle: 'Edit Profile' }) %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">The Void</div>
    <h1 class="auth-title">Edit profile</h1>
    <p class="auth-sub">Update your username and bio.</p>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <form action="/profile/<%= user.username %>/edit" method="POST" class="auth-form">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" value="<%= user.username %>" required minlength="3" maxlength="30" />
      </div>
      <div class="form-group">
        <label>Bio <span class="optional">(optional)</span></label>
        <textarea name="bio" rows="3" maxlength="200" placeholder="A short description about you…"><%= user.bio || '' %></textarea>
      </div>
      <button type="submit" class="btn-primary full-width">Save changes</button>
    </form>

    <p class="auth-switch"><a href="/profile/<%= user.username %>">&larr; Back to profile</a></p>
  </div>
</div>

<%- include('../partials/footer') %>
