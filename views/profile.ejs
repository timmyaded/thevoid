<%- include('partials/header', { pageTitle: profileUser.username }) %>

<div class="profile-page">
  <div class="profile-header">
    <div class="profile-avatar-lg"><%= profileUser.username.charAt(0).toUpperCase() %></div>
    <div class="profile-info">
      <h1 class="profile-username"><%= profileUser.username %></h1>
      <% if (profileUser.bio) { %>
        <p class="profile-bio"><%= profileUser.bio %></p>
      <% } %>
      <p class="profile-joined">Member since <%= new Date(profileUser.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>
    </div>
  </div>

  <div class="profile-content">
    <div class="profile-posts-header">
      <h2 class="section-label">Posts <span class="post-count"><%= posts.length %></span></h2>
      <% if (currentUsername === profileUser.username) { %>
        <div class="profile-actions">
          <a href="/profile/<%= profileUser.username %>/edit" class="action-btn">Edit profile</a>
          <a href="/posts/new" class="btn-write-inline">+ New Post</a>
        </div>
      <% } %>
    </div>

    <% if (posts.length === 0) { %>
      <div class="empty-feed">
        <span class="empty-glyph">✦</span>
        <p>No posts yet.</p>
        <% if (currentUsername === profileUser.username) { %>
          <a href="/posts/new" class="btn-primary">Write your first post</a>
        <% } %>
      </div>
    <% } else { %>
      <div class="post-list">
        <% posts.forEach((post, i) => { %>
          <article class="post-item" style="animation-delay:<%= i * 50 %>ms">
            <div class="post-item-meta">
              <span class="post-date"><%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
            </div>
            <div class="post-item-body">
              <div class="post-item-text">
                <h2 class="post-item-title">
                  <a href="/posts/<%= post._id %>"><%= post.title %></a>
                </h2>
                <p class="post-item-excerpt"><%= post.content.substring(0, 160) %><%= post.content.length > 160 ? '…' : '' %></p>
              </div>
            </div>
            <div class="post-item-footer">
              <a href="/feed/<%= post.category.toLowerCase() %>" class="post-tag"><%= post.category %></a>
              <span class="post-read-time"><%= post.readTime %></span>
              <% if (currentUsername === profileUser.username) { %>
                <div class="ml-auto post-actions-inline">
                  <a href="/posts/<%= post._id %>/edit" class="action-btn">Edit</a>
                  <form action="/posts/<%= post._id %>/delete" method="POST" class="inline-form">
                    <button class="action-btn danger" onclick="return confirm('Delete this post?')">Delete</button>
                  </form>
                </div>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
