<%- include('../partials/header', { pageTitle: 'Edit Post', categories, activeCategory: null }) %>

<div class="write-page">
  <div class="write-inner">
    <h1 class="write-title">Edit Post</h1>

    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <form action="/posts/<%= post._id %>/edit" method="POST" enctype="multipart/form-data" class="post-form">
      <div class="form-group">
        <input type="text" name="title" value="<%= post.title %>" required class="title-input" />
      </div>

      <div class="form-row">
        <div class="form-group flex-1">
          <label>Category</label>
          <select name="category">
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= post.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="word-count-display">
          <span id="wordCount">0</span> words
        </div>
      </div>

      <div class="form-group">
        <label>Cover image <span class="optional">(optional · max 5MB)</span></label>

        <% if (post.coverImageType) { %>
          <div class="current-image-preview">
            <img src="/posts/<%= post._id %>/image" alt="Current cover" />
            <span class="current-image-label">Current image — upload a new one to replace it</span>
          </div>
          <label class="remove-image-label">
            <input type="checkbox" name="removeImage" value="1" />
            Remove cover image
          </label>
        <% } %>

        <input type="file" name="coverImage" accept="image/*" class="file-input" />
      </div>

      <div class="form-group">
        <label>Your story</label>
        <textarea name="content" id="content" rows="18" required><%= post.content %></textarea>
      </div>

      <div class="form-actions">
        <a href="/posts/<%= post._id %>" class="btn-ghost">Cancel</a>
        <button type="submit" class="btn-primary">Save changes</button>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
